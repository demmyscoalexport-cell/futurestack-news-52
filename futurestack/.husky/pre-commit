#!/bin/sh
echo "🔍 FutureStack pre-commit guard running..."
npx lint-staged
echo "🔬 Running TypeScript check..."
npx tsc --noEmit
if [ $? -ne 0 ]; then
  echo "❌ TypeScript errors found. Fix before committing."
  echo "Run: npm run check to see all errors"
  exit 1
fi
echo "✅ All clean. Committing."

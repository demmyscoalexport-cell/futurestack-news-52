# ================================================
# FUTURESTACK — COMPLETE ENVIRONMENT VARIABLES
# ================================================
# Copy this file to .env.local and fill in values
# NEVER commit .env.local to Git — it is in .gitignore
# ================================================

# SUPABASE — database, auth, storage
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# SITE URL — your actual domain (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://futurestack.live

# FLUTTERWAVE — primary payment processor
FLUTTERWAVE_SECRET_KEY=
NEXT_PUBLIC_FLUTTERWAVE_PUBLIC_KEY=
FLUTTERWAVE_WEBHOOK_HASH=

# PAYSTACK — secondary payment processor (Nigeria)
PAYSTACK_SECRET_KEY=
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=

# RESEND — transactional emails (receipts, alerts, verification)
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# LOOPS — email marketing, onboarding sequences, newsletters
LOOPS_API_KEY=

# ONESIGNAL — web push notifications to users
NEXT_PUBLIC_ONESIGNAL_APP_ID=
ONESIGNAL_API_KEY=

# INNGEST — background jobs and scheduled tasks
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
INNGEST_DEV=1

# SENTRY — runtime error monitoring (client + server)
NEXT_PUBLIC_SENTRY_DSN=

# STRIPE — payment processing (future premium tiers)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# OPENAI — GPT-4o for content generation and processing
OPENAI_API_KEY=

# ANTHROPIC — Claude Sonnet for content editing and review
ANTHROPIC_API_KEY=

# FAL.AI — AI image generation for article thumbnails
FAL_KEY=

# REPLICATE — additional AI model inference
REPLICATE_API_TOKEN=

# TAVILY — AI-powered web search for content sourcing
TAVILY_API_KEY=

# TAVILY REMOTE — extended Tavily access for remote pipeline
TAVILY_REMOTE_KEY=

# GOOGLE — Search API and Programmable Search Engine
GOOGLE_API_KEY=
GOOGLE_SEARCH_ENGINE_ID=

# NEWS API — real-time news headlines and article sourcing
NEWS_API_KEY=

# POSTDOG — automated social media posting and scheduling
POSTDOG_API_KEY=

# SAMPLING API — web content extraction for AI pipeline
# Used to scrape and extract clean content from AI tool
# websites before feeding into the content pipeline
SAMPLING_API_KEY=

# CONTENTFUL — headless CMS for tools/news/comparisons/stacks
CONTENTFUL_SPACE_ID=
CONTENTFUL_ENVIRONMENT=master
CONTENTFUL_ENVIRONMENT_ID=master
CONTENTFUL_DELIVERY_TOKEN=
CONTENTFUL_PREVIEW_TOKEN=
CONTENTFUL_MANAGEMENT_TOKEN=
CONTENTFUL_USE_PREVIEW_API=false
CONTENTFUL_WEBHOOK_SECRET=
CONTENTFUL_DEFAULT_LOCALE=en-US

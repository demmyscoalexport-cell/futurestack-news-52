# ================================================================
# DISCOVA — Complete Environment Variables
# ================================================================
# 1. Copy this file:  cp .env.example .env.local
# 2. Fill in every value below
# 3. NEVER commit .env.local — it is in .gitignore
# ================================================================

# ── CLERK (authentication) ───────────────────────────────────────
# From: https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# From: Clerk Dashboard → Webhooks → Signing secret (for /api/webhooks/clerk)
CLERK_WEBHOOK_SECRET=
# Optional: custom sign-in/up URLs (defaults to /sign-in and /sign-up)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# ── SUPABASE (database + auth) ───────────────────────────────────
# From: https://app.supabase.com → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# From: Settings → Database → Connection string (Transaction pooler, port 6543)
SUPABASE_DB_URL=
SUPABASE_DB_PASSWORD=
# From: https://app.supabase.com/account/tokens (used only for schema migrations)
SUPABASE_MANAGEMENT_TOKEN=

# ── SITE URL ──────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# ── WEB PUSH NOTIFICATIONS (VAPID) ───────────────────────────────
# Generate once with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:hello@yourdomain.com

# ── NEWS / DATA SOURCES ───────────────────────────────────────────
# GNews: https://gnews.io/dashboard
GNEWS_API_KEY=
# ProductHunt: https://api.producthunt.com/v2/oauth/applications
PRODUCTHUNT_API_TOKEN=
# ScrapingBee: https://app.scrapingbee.com/account
SCRAPINGBEE_API_KEY=

# ── AI (content generation) ───────────────────────────────────────
# Anthropic Claude — used for article writing (Replit AI integration handles this)
# ANTHROPIC_API_KEY=

# WaveSpeed — AI logo / image generation
WAVESPEED_API_KEY=

# ── CLOUDINARY (image hosting) ────────────────────────────────────
# From: https://console.cloudinary.com
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_URL=

# ── INNGEST (background jobs / scheduled tasks) ───────────────────
INNGEST_DEV=1
# In production, get these from https://www.inngest.com
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ── SESSION / COOKIES ─────────────────────────────────────────────
SESSION_SECRET=change-this-to-a-random-64-char-string

# ── RESEND (transactional email) ──────────────────────────────────
# From: https://resend.com/api-keys
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@yourdomain.com

# ── GOOGLE ANALYTICS 4 (optional) ────────────────────────────────
# From: https://analytics.google.com → Admin → Data Streams
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ── CONTENTFUL (headless CMS, optional) ──────────────────────────
# From: https://www.contentful.com → Settings → API Keys
CONTENTFUL_SPACE_ID=
CONTENTFUL_ENVIRONMENT=master
CONTENTFUL_DELIVERY_TOKEN=
CONTENTFUL_PREVIEW_TOKEN=
CONTENTFUL_MANAGEMENT_TOKEN=
CONTENTFUL_WEBHOOK_SECRET=

# ── STRIPE (payments, optional) ───────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── FLUTTERWAVE (Africa payments, optional) ───────────────────────
FLUTTERWAVE_SECRET_KEY=
NEXT_PUBLIC_FLUTTERWAVE_PUBLIC_KEY=
FLUTTERWAVE_WEBHOOK_HASH=

# ── PAYSTACK (Nigeria payments, optional) ─────────────────────────
PAYSTACK_SECRET_KEY=
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=

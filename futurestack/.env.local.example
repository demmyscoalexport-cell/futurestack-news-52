# ─────────────────────────────────────────────
# SUPABASE
# ─────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server-only, never expose to browser

# ─────────────────────────────────────────────
# AI PROVIDERS
# ─────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_GENERATIVE_AI_API_KEY=AIza...
FAL_KEY=your-fal-ai-key
REPLICATE_API_TOKEN=r8_...

# ─────────────────────────────────────────────
# STRIPE
# ─────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─────────────────────────────────────────────
# EMAIL — RESEND
# ─────────────────────────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@yourdomain.com

# ─────────────────────────────────────────────
# PUSH NOTIFICATIONS — ONESIGNAL
# ─────────────────────────────────────────────
NEXT_PUBLIC_ONESIGNAL_APP_ID=your-onesignal-app-id

# ─────────────────────────────────────────────
# MONITORING — SENTRY
# ─────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
SENTRY_AUTH_TOKEN=your-sentry-auth-token
SENTRY_ORG=your-org
SENTRY_PROJECT=your-project

# ─────────────────────────────────────────────
# ANALYTICS — POSTHOG (already in package.json)
# ─────────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ─────────────────────────────────────────────
# SITE
# ─────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─────────────────────────────────────────────
# CONTENTFUL CMS
# ─────────────────────────────────────────────
CONTENTFUL_SPACE_ID=your-contentful-space-id
CONTENTFUL_ENVIRONMENT=master
CONTENTFUL_ENVIRONMENT_ID=master
CONTENTFUL_DELIVERY_TOKEN=your-content-delivery-api-token
CONTENTFUL_PREVIEW_TOKEN=your-content-preview-api-token
CONTENTFUL_MANAGEMENT_TOKEN=your-content-management-api-token
CONTENTFUL_USE_PREVIEW_API=false
CONTENTFUL_WEBHOOK_SECRET=your-contentful-webhook-shared-secret
CONTENTFUL_DEFAULT_LOCALE=en-US
